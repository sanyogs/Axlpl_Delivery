{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "adb: wireless connect",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/adb_wireless_connect.sh",
      "options": {
        "env": {
          "ADB_MDNS_AUTO_CONNECT": "adb-tls-connect,adb",
          "ADB_FULL_SCAN": "0"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "adb: wireless watch",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/adb_wireless_watch.sh",
      "isBackground": true,
      "options": {
        "env": {
          "ADB_MDNS_AUTO_CONNECT": "adb-tls-connect,adb",
          "ADB_FULL_SCAN": "0"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "flutter: attach watch (Pixel 7)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/flutter_attach_watch.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
